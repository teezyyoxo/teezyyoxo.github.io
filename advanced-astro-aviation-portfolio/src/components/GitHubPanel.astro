  color:var(--accent);
  font-family:'JetBrains Mono', monospace;
  font-size:0.8rem;
  letter-spacing:3px;
  margin-bottom:10px;
  text-transform:uppercase;
}

.header a{
  color:var(--accent);
  text-decoration:none;
  border:1px solid var(--border);
  border-radius:10px;
  padding:10px 14px;
  white-space:nowrap;
}

.github-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:24px;
}

.github-card{
  background:rgba(255,255,255,0.03);
  border:1px solid var(--border);
  border-radius:8px;
  padding:24px;
}

.github-card h3{
