
<section class="github-section" id="lab">

  <div class="header">
    <div>
      <p class="section-kicker">Lab</p>
      <h2>GitHub Activity</h2>
    </div>
    <a href="https://github.com/teezyyoxo" target="_blank" rel="noreferrer">View Profile</a>
  </div>

  <div class="github-grid">

    <div class="github-card">
      <h3>Recent Public Activity</h3>
      <ul id="github-feed">
        <li>Loading GitHub activity...</li>
      </ul>
    </div>

    <div class="github-card">
      <h3>Current Stack</h3>

      <div class="stack">
        <span>Python</span>
        <span>SwiftUI</span>
        <span>Docker</span>
        <span>Kubernetes</span>
        <span>Flask</span>
        <span>Astro</span>
        <span>Tailwind CSS</span>
      </div>
    </div>

  </div>

</section>

<script>
  const username = 'teezyyoxo';

  async function loadGitHub(){
    const feed = document.getElementById('github-feed');

    try{
      const res = await fetch(`https://api.github.com/users/${username}/events/public`);
      if(!res.ok) throw new Error(`GitHub API responded with ${res.status}`);

      const data = await res.json();

      feed.innerHTML = '';

      if(!Array.isArray(data) || data.length === 0){
        feed.innerHTML = '<li>No recent public activity found.</li>';
        return;
      }

      data.slice(0,5).forEach(event => {
        const li = document.createElement('li');
        const repo = event.repo?.name || 'unknown repository';
        const type = event.type.replace('Event', '');
        li.textContent = `${type} -> ${repo}`;
        feed.appendChild(li);
      });

    }catch(err){
      feed.innerHTML =
        '<li>GitHub activity is temporarily unavailable.</li>';
    }
  }

  loadGitHub();
</script>

