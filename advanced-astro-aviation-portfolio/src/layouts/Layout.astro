
---
const title = 'Montel Gray | Developer & Systems Builder';
const description = 'Portfolio for Montel Gray, featuring personal and work-adjacent software projects across automation, infrastructure, diagnostics, creative tooling, web interfaces, and aviation-inspired systems.';
---

<!DOCTYPE html>
<html lang="en" id="top">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#08111d" />
  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

  <style is:global>
    :root{
      --accent:#00e0b8;
      --bg:#08111d;
      --panel:rgba(255,255,255,0.05);
      --border:rgba(255,255,255,0.08);
      --text:#e8f4ff;
      --muted:#88a3b8;
    }

    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
    }

    body{
      background: radial-gradient(circle at top, #10263c 0%, #08111d 65%);
      color:var(--text);
      font-family:'Inter', sans-serif;
      overflow-x:hidden;
    }

    html{
      scroll-behavior:smooth;
    }

    :focus-visible{
      outline:2px solid var(--accent);
      outline-offset:4px;
    }

    canvas#bg{
      position:fixed;
      inset:0;
      z-index:-1;
      opacity:0.32;
    }

    .glass{
      background:rgba(255,255,255,0.035);
      backdrop-filter:blur(18px);
      border:1px solid var(--border);
      box-shadow:0 0 30px rgba(0,224,184,0.05);
    }

    .terminal-loader{
      position:fixed;
      inset:0;
      background:#050b13;
      display:flex;
      align-items:center;
      justify-content:center;
      z-index:9999;
      transition:opacity 1s ease;
    }

    .terminal-box{
      width:min(90%,700px);
      border-radius:18px;
      overflow:hidden;
      border:1px solid rgba(0,224,184,0.25);
      background:#071018;
      box-shadow:0 0 40px rgba(0,224,184,0.12);
    }

    .terminal-header{
      padding:14px 18px;
      border-bottom:1px solid rgba(255,255,255,0.08);
      font-family:'JetBrains Mono', monospace;
      color:var(--accent);
    }

    .terminal-content{
      padding:24px;
      font-family:'JetBrains Mono', monospace;
      line-height:2;
      color:#dffcf6;
    }

    .typing::after{
      content:'_';
      animation:blink 1s infinite;
    }

    @keyframes blink{
      50%{opacity:0;}
    }

    .hidden-loader{
      opacity:0;
      pointer-events:none;
    }

  </style>
</head>
<body>

<div id="loader" class="terminal-loader">
  <div class="terminal-box">
    <div class="terminal-header">
      portfolio://system_boot
    </div>

    <div class="terminal-content">
      <div>> Loading project index...</div>
      <div>> Linking repositories and experiments...</div>
      <div>> Syncing GitHub activity...</div>
      <div class="typing">> Ready</div>
    </div>
  </div>
</div>

<canvas id="bg"></canvas>

<slot />

<script>
  function hideLoader(){
    setTimeout(() => {
      document.getElementById('loader')?.classList.add('hidden-loader');
    }, 3200);
  }

  if(document.readyState === 'complete'){
    hideLoader();
  }else{
    window.addEventListener('load', hideLoader);
  }

  const canvas = document.getElementById('bg');
  const ctx = canvas.getContext('2d');

  function resize(){
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  resize();
  window.addEventListener('resize', resize);

  const particles = Array.from({length:65}, () => ({
    x:Math.random()*canvas.width,
    y:Math.random()*canvas.height,
    r:Math.random()*1.8,
    dx:(Math.random()-0.5)*0.2,
    dy:(Math.random()-0.5)*0.2
  }));

  function animate(){
    ctx.clearRect(0,0,canvas.width,canvas.height);

    particles.forEach(p=>{
      p.x += p.dx;
      p.y += p.dy;

      if(p.x < 0 || p.x > canvas.width) p.dx *= -1;
      if(p.y < 0 || p.y > canvas.height) p.dy *= -1;

      ctx.beginPath();
      ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle = 'rgba(0,224,184,0.35)';
      ctx.fill();
    });

    requestAnimationFrame(animate);
  }

  animate();
</script>

</body>
</html>
